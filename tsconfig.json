{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vitest"]
  },
  "include": ["extension.ts", "protocol/**/*.ts", "src/**/*.ts", "tests/**/*.ts"]
}
